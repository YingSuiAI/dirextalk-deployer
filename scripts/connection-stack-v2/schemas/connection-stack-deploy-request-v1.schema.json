{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:dirextalk:schema:aws:connection-stack-deploy-request:v1",
  "title": "Dirextalk AWS Connection Stack V2 deployment request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "bootstrap_id",
    "stack_name",
    "connection_id",
    "connection_generation",
    "requested_region",
    "node_key_id",
    "node_public_key_spki_b64",
    "device_approval_key_id",
    "device_approval_public_key_spki_b64",
    "stage_name",
    "worker_base_ami_id",
    "worker_vpc_id",
    "worker_subnet_id",
    "worker_availability_zone",
    "worker_resource_manifest_digest",
    "template_sha256",
    "source_tree_sha256"
  ],
  "properties": {
    "schema": { "const": "dirextalk.aws.connection-stack-deploy-request/v1" },
    "bootstrap_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{7,127}$" },
    "stack_name": { "type": "string", "pattern": "^[A-Za-z][-A-Za-z0-9]{0,127}$" },
    "connection_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{7,127}$" },
    "connection_generation": { "type": "integer", "minimum": 1 },
    "requested_region": { "type": "string", "pattern": "^(?:af|ap|ca|cn|eu|il|me|mx|sa|us)(?:-gov)?-[a-z]+-\\d$" },
    "node_key_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$" },
    "node_public_key_spki_b64": { "type": "string", "contentEncoding": "base64" },
    "device_approval_key_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$" },
    "device_approval_public_key_spki_b64": { "type": "string", "contentEncoding": "base64" },
    "stage_name": { "type": "string", "pattern": "^[A-Za-z0-9_-]{1,32}$" },
    "worker_base_ami_id": { "type": "string", "pattern": "^ami-[0-9a-f]{8,17}$" },
    "worker_vpc_id": { "type": "string", "pattern": "^vpc-[0-9a-f]{8,17}$" },
    "worker_subnet_id": { "type": "string", "pattern": "^subnet-[0-9a-f]{8,17}$" },
    "worker_availability_zone": { "type": "string", "pattern": "^(?:af|ap|ca|cn|eu|il|me|mx|sa|us)(?:-gov)?-[a-z]+-\\d[a-z]$" },
    "worker_resource_manifest_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "template_sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "source_tree_sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  }
}
