{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:dirextalk:schema:aws:deployment-receipt:v1",
  "title": "Dirextalk private isolated Worker deployment receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "connection_id",
    "deployment_id",
    "request_sha256",
    "resource_status",
    "instance_id",
    "volume_ids",
    "network_interface_ids"
  ],
  "properties": {
    "schema": { "const": "dirextalk.aws.deployment-receipt/v1" },
    "connection_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{7,127}$" },
    "deployment_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{7,127}$" },
    "request_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "resource_status": { "enum": ["provisioning", "active", "degraded", "destroying", "destroy_blocked", "verified_destroyed"] },
    "instance_id": { "type": "string", "pattern": "^i-[0-9a-f]{8,17}$" },
    "volume_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^vol-[0-9a-f]{8,17}$" }
    },
    "network_interface_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^eni-[0-9a-f]{8,17}$" }
    }
  }
}
