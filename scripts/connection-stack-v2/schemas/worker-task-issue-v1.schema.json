{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:dirextalk:schema:worker-task-issue:v1",
  "title": "Dirextalk Worker task issue v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "deployment_id",
    "task_id",
    "task_kind",
    "execution_manifest_digest",
    "input_digest"
  ],
  "properties": {
    "schema": { "const": "dirextalk.worker-task-issue/v1" },
    "deployment_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{7,127}$" },
    "task_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{7,127}$" },
    "task_kind": { "const": "execution_probe" },
    "execution_manifest_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "input_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  }
}
