[Unit]
Description=Dirextalk host updater
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
Group=root
ExecStart=/usr/local/bin/dirextalk-updater --config /etc/dirextalk-updater/config.json serve
Restart=on-failure
RestartSec=5s
RuntimeDirectory=dirextalk-updater
RuntimeDirectoryMode=0755
StateDirectory=dirextalk-updater
StateDirectoryMode=0700
ConfigurationDirectory=dirextalk-updater
ConfigurationDirectoryMode=0700
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/var/lib/dirextalk-updater /run/dirextalk-updater

[Install]
WantedBy=multi-user.target
